# Core
ENVIRONMENT=development

# Database (Supabase Postgres pooler — pgbouncer, port 6543)
DATABASE_URL=postgresql+asyncpg://user:password@host:6543/postgres

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# ShipsGo container tracking API (v2 Ocean)
SHIPSGO_API_KEY=your-shipsgo-user-token
SHIPSGO_API_BASE_URL=https://api.shipsgo.com/v2

# Groq (AI alert generation + logistics agent)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-8b-instant
GROQ_MODEL_AGENT=qwen/qwen3-32b

# Langfuse (LLM observability — https://cloud.langfuse.com)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# Mem0 (agent conversation memory — https://app.mem0.ai)
MEM0_API_KEY=m0-...

# Email (Postmark)
EMAIL_FROM=noreply@yourdomain.com
POSTMARK_SERVER_TOKEN=your-postmark-token

# WhatsApp Business API (Meta)
WHATSAPP_ACCESS_TOKEN=your-meta-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# API security — set a strong random secret
API_KEY=your-strong-random-api-key
